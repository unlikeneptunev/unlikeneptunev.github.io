---

---

<div
    id="search-overlay"
    class="search-overlay"
    aria-hidden="true"
    data-pagefind-ignore
>
    <div class="search-modal">
        <div class="search-input-wrap">
            <span class="search-icon">_</span>
            <input
                type="text"
                id="search-input"
                class="search-input"
                placeholder="search anything..."
                autocomplete="off"
                spellcheck="false"
            />
            <kbd class="search-esc">esc</kbd>
        </div>
        <div id="search-results" class="search-results"></div>
    </div>
</div>

<style>
    .search-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.75);
        z-index: 200;
        display: flex;
        align-items: flex-start;
        justify-content: center;
        padding-top: 12vh;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.15s ease;
    }

    .search-overlay.active {
        opacity: 1;
        pointer-events: all;
    }

    .search-modal {
        width: 100%;
        max-width: 600px;
        margin: 0 1.5rem;
        background: var(--bg-secondary);
        border: 1px solid var(--border);
    }

    .search-input-wrap {
        display: flex;
        align-items: center;
        padding: 1rem 1.25rem;
        border-bottom: 1px solid var(--border);
        gap: 0.75rem;
    }

    .search-icon {
        color: var(--text-secondary);
        font-size: var(--size-base);
    }

    .search-input {
        flex: 1;
        background: none;
        border: none;
        color: var(--text-primary);
        font-family: var(--font);
        font-size: var(--size-base);
        padding: 0;
        outline: none;
        width: 100%;
    }

    .search-input::placeholder {
        color: var(--text-muted);
    }

    .search-esc {
        background: var(--bg);
        border: 1px solid var(--border);
        color: var(--text-secondary);
        padding: 0.15rem 0.4rem;
        font-size: var(--size-xs);
        font-family: var(--font);
        border-radius: 3px;
        box-shadow: 0 1px 0 var(--border);
    }

    .search-results {
        max-height: 50vh;
        overflow-y: auto;
        border-top: none;
    }

    .search-results:empty {
        display: none;
    }

    .pagefind-result {
        padding: 0.65rem 1.25rem;
    }

    .result-path {
        font-size: var(--size-base);
        font-weight: 700;
        color: var(--text-primary);
        display: block;
        margin-bottom: 0.25rem;
    }

    .result-path::after {
        display: none;
    }

    .result-excerpt {
        font-size: var(--size-sm);
        color: var(--text-secondary);
        line-height: 1.6;
        display: block;
        margin: 0;
    }

    .result-excerpt mark {
        background: none;
        color: #d4a017;
        font-weight: 700;
    }

    .no-results {
        padding: 1rem 1.25rem;
        font-size: var(--size-sm);
        color: var(--text-secondary);
    }
</style>

<script>
    declare global {
        interface Window {
            pagefind: any;
        }
    }

    let pagefind: any = null;
    const overlay = document.getElementById("search-overlay");
    const input = document.getElementById("search-input") as HTMLInputElement;
    const resultsContainer = document.getElementById("search-results");

    async function initPagefind() {
        if (pagefind) return;
        try {
            pagefind = await import("/pagefind/pagefind.js" as any);
            await pagefind.options({
                excerptLength: 15,
            });
        } catch (e) {
            console.error("Failed to load pagefind", e);
        }
    }

    function openSearch() {
        overlay?.classList.add("active");
        overlay?.setAttribute("aria-hidden", "false");
        setTimeout(() => input?.focus(), 50);
        initPagefind();
    }

    function closeSearch() {
        overlay?.classList.remove("active");
        overlay?.setAttribute("aria-hidden", "true");
        if (input) input.value = "";
        if (resultsContainer) resultsContainer.innerHTML = "";
    }

    document.addEventListener("keydown", (e) => {
        const target = e.target as HTMLElement;
        const tag = (target as HTMLElement).tagName;
        const isTyping = tag === "INPUT" || tag === "TEXTAREA";

        if (e.key === "/" && !isTyping) {
            e.preventDefault();
            openSearch();
        }
        if (e.key === "Escape") closeSearch();
    });

    document.addEventListener("open-search", openSearch);

    overlay?.addEventListener("click", (e) => {
        if (e.target === overlay) closeSearch();
    });

    input?.addEventListener("input", async () => {
        if (!pagefind || !resultsContainer) return;
        const query = input.value.trim();

        if (!query) {
            resultsContainer.innerHTML = "";
            return;
        }

        const search = await pagefind.search(query);

        if (search.results.length === 0) {
            resultsContainer.innerHTML = `<p class="no-results">no results for "${query}"</p>`;
            return;
        }

        const top = await Promise.all(
            search.results.slice(0, 8).map((r: any) => r.data()),
        );

        resultsContainer.innerHTML = top
            .map((r: any) => {
                const url = r.url;
                const pathLabel =
                    url.replace(/^\//, "").replace(/\/$/, "") || "home";
                return `
            <div class="pagefind-result">
              <a href="${url}" class="result-path">${pathLabel}</a>
              <p class="result-excerpt">${r.excerpt}</p>
            </div>
          `;
            })
            .join("");
    });
</script>
