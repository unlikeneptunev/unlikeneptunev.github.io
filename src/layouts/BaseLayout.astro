---
interface Props {
    title: string;
    description?: string;
}
const { title, description = "blogs and stuff" } = Astro.props;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta
            name="viewport"
            content="width=device-width, initial-scale=1.0, maximum-scale=1.0"
        />
        <meta name="description" content={description} />
        <title>{title} | unlikeneptune</title>
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&display=swap"
            rel="stylesheet"
        />
        <link
            rel="icon"
            href="/images/title_icon/mihono-bourbon-hacking.png"
            type="image/png"
        />
        <style is:global>
            :root {
                --bg: #0d0d0d;
                --bg-secondary: #141414;
                --border: #4f4e4e;
                --text-primary: #c9c9c9;
                --text-secondary: #5a5a5a;
                --text-muted: #333333;
                --accent: #c9c9c9;
                --accent-hover: #ffffff;
                --link: #c9c9c9;
                --link-hover: #ffffff;
                --font: "JetBrains Mono", monospace;
                --size-base: 15px;
                --size-sm: 13px;
                --size-lg: 22px;
                --size-xl: 32px;
                --content-width: 860px;
                --gap: 2.5rem;
            }

            [data-theme="light"] {
                --bg: #f5f5f0;
                --bg-secondary: #ebebeb;
                --border: #c0bfbf;
                --text-primary: #1a1a1a;
                --text-secondary: #6b6b6b;
                --text-muted: #a0a0a0;
                --accent: #1a1a1a;
                --accent-hover: #000000;
                --link: #1a1a1a;
                --link-hover: #000000;
                --question-color: #e8b22c;
            }

            *,
            *::before,
            *::after {
                box-sizing: border-box;
                margin: 0;
                padding: 0;
            }

            html {
                background-color: var(--bg);
                color: var(--text-primary);
                font-family: var(--font);
                font-size: var(--size-base);
                line-height: 1.7;
                -webkit-font-smoothing: antialiased;
                transition:
                    background-color 0.3s ease,
                    color 0.3s ease;
            }

            body {
                min-height: 100vh;
                display: flex;
                flex-direction: column;
            }

            body::before,
            body::after {
                content: "";
                position: fixed;
                top: 0;
                bottom: 0;
                width: 1px;
                background-color: var(--border);
                z-index: 50;
            }

            body::before {
                left: 2rem;
            }

            body::after {
                right: 2rem;
            }

            a {
                color: var(--link);
                text-decoration: none;
                position: relative;
            }

            a:visited {
                color: var(--link);
            }

            a::after {
                content: "";
                position: absolute;
                bottom: -1px;
                left: 0;
                width: 0;
                height: 1px;
                background-color: currentColor;
                transition: width 0.25s ease;
            }

            a:hover {
                color: var(--link-hover);
            }

            a:hover::after {
                width: 100%;
            }

            .container {
                width: 100%;
                max-width: var(--content-width);
                margin: 0 auto;
                padding: 0 2rem;
            }

            .page-wrapper {
                flex: 1;
                padding-top: 5rem;
                padding-bottom: 5rem;
            }

            .back-link {
                display: inline-block;
                font-size: var(--size-sm);
                color: var(--text-secondary);
                text-transform: uppercase;
                letter-spacing: 0.08em;
                margin-bottom: 3rem;
                transition: color 0.15s;
            }

            .back-link:visited {
                color: var(--text-secondary);
            }

            .back-link:hover {
                color: var(--text-primary);
            }

            @media (max-width: 600px) {
                body::before,
                body::after {
                    display: none;
                }
            }
        </style>
        <script is:inline>
            const saved = localStorage.getItem("theme");
            if (saved === "light") {
                document.documentElement.setAttribute("data-theme", "light");
            }
        </script>
    </head>
    <body>
        <slot />
        <button id="theme-toggle" aria-label="toggle theme" data-pagefind-ignore
            >light</button
        >

        <style is:global>
            #theme-toggle {
                position: fixed;
                bottom: 1.5rem;
                right: 3.5rem;
                background: none;
                border: 1px solid var(--border);
                cursor: pointer;
                color: var(--text-secondary);
                font-size: var(--size-sm);
                font-family: var(--font);
                padding: 0.35rem 1rem;
                transition:
                    color 0.15s,
                    border-color 0.15s;
                z-index: 100;
                letter-spacing: 0.05em;
            }

            #theme-toggle:hover {
                color: var(--text-primary);
                border-color: var(--text-primary);
            }
        </style>

        <script>
            const toggle = document.getElementById("theme-toggle");
            const html = document.documentElement;

            const saved = localStorage.getItem("theme");
            if (saved === "light") {
                html.setAttribute("data-theme", "light");
                if (toggle) toggle.textContent = "dark";
            }

            toggle?.addEventListener("click", () => {
                const isLight = html.getAttribute("data-theme") === "light";
                if (isLight) {
                    html.removeAttribute("data-theme");
                    localStorage.setItem("theme", "dark");
                    toggle.textContent = "light";
                } else {
                    html.setAttribute("data-theme", "light");
                    localStorage.setItem("theme", "light");
                    toggle.textContent = "dark";
                }
            });
        </script>
    </body>
</html>
