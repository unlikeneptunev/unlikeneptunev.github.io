---
interface Props {
    title: string;
    description?: string;
}
const { title, description = "blogs and stuff" } = Astro.props;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta
            name="viewport"
            content="width=device-width, initial-scale=1.0, maximum-scale=1.0"
        />
        <meta name="description" content={description} />
        <title>{title} | unlikeneptune</title>
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&display=swap"
            rel="stylesheet"
        />
        <link
            rel="icon"
            href="/images/title_icon/mihono-bourbon-hacking.png"
            type="image/png"
        />
        <style is:global>
            :root {
                --bg: #0d0d0d;
                --bg-secondary: #141414;
                --border: #4f4e4e;
                --text-primary: #c9c9c9;
                --text-secondary: #5a5a5a;
                --text-muted: #333333;
                --accent: #c9c9c9;
                --accent-hover: #ffffff;
                --link: #c9c9c9;
                --link-hover: #ffffff;
                --font: "JetBrains Mono", monospace;
                --size-base: 15px;
                --size-sm: 13px;
                --size-lg: 22px;
                --size-xl: 32px;
                --content-width: 860px;
                --gap: 2.5rem;
            }

            *,
            *::before,
            *::after {
                box-sizing: border-box;
                margin: 0;
                padding: 0;
            }

            html {
                background-color: var(--bg);
                color: var(--text-primary);
                font-family: var(--font);
                font-size: var(--size-base);
                line-height: 1.7;
                -webkit-font-smoothing: antialiased;
            }

            body {
                min-height: 100vh;
                display: flex;
                flex-direction: column;
            }

            body::before,
            body::after {
                content: "";
                position: fixed;
                top: 0;
                bottom: 0;
                width: 1px;
                background-color: var(--border);
                z-index: 50;
            }

            body::before {
                left: 2rem;
            }

            body::after {
                right: 2rem;
            }

            a {
                color: var(--link);
                text-decoration: none;
                position: relative;
            }

            a:visited {
                color: var(--link);
            }

            a::after {
                content: "";
                position: absolute;
                bottom: -1px;
                left: 0;
                width: 0;
                height: 1px;
                background-color: currentColor;
                transition: width 0.25s ease;
            }

            a:hover {
                color: var(--link-hover);
            }

            a:hover::after {
                width: 100%;
            }

            .container {
                width: 100%;
                max-width: var(--content-width);
                margin: 0 auto;
                padding: 0 2rem;
            }

            .page-wrapper {
                flex: 1;
                padding-top: 5rem;
                padding-bottom: 5rem;
            }

            .back-link {
                display: inline-block;
                font-size: var(--size-sm);
                color: var(--text-secondary);
                text-transform: uppercase;
                letter-spacing: 0.08em;
                margin-bottom: 3rem;
                transition: color 0.15s;
            }

            .back-link:visited {
                color: var(--text-secondary);
            }

            .back-link:hover {
                color: var(--text-primary);
            }

            @media (max-width: 600px) {
                body::before,
                body::after {
                    display: none;
                }
            }
        </style>
    </head>
    <body>
        <slot />
    </body>
</html>
