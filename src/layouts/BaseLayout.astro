---
import Search from "../components/Search.astro";
interface Props {
    title: string;
    description?: string;
}
const { title, description = "blogs and stuff" } = Astro.props;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta
            name="viewport"
            content="width=device-width, initial-scale=1.0, maximum-scale=1.0"
        />
        <meta name="description" content={description} />
        <title>{title} | unlikeneptune</title>
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&display=swap"
            rel="stylesheet"
        />
        <link
            rel="icon"
            href="/images/title_icon/mihono-bourbon-hacking.png"
            type="image/png"
        />
        <style is:global>
            :root {
                --bg: #0d0d0d;
                --bg-secondary: #141414;
                --border: #4f4e4e;
                --text-primary: #c9c9c9;
                --text-secondary: #5a5a5a;
                --text-muted: #333333;
                --font: "JetBrains Mono", monospace;
                --size-xs: 0.75rem;
                --size-sm: 0.875rem;
                --size-base: 1rem;
                --size-lg: 1.25rem;
                --size-xl: 1.5rem;
                --size-2xl: 2rem;
            }

            html {
                background-color: var(--bg);
                color: var(--text-primary);
                font-family: var(--font);
                font-size: var(--size-base);
                line-height: 1.7;
                -webkit-font-smoothing: antialiased;
                overflow-x: hidden;
            }

            body {
                min-height: 100vh;
                display: flex;
                flex-direction: column;
                overflow-x: hidden;
            }

            .search-trigger {
                position: fixed;
                bottom: 1.5rem;
                left: 50%;
                transform: translate3d(-50%, 0, 0);
                background: var(--bg-secondary);
                border: 1px solid var(--border);
                cursor: pointer;
                color: var(--text-secondary);
                font-size: var(--size-sm);
                font-family: var(--font);
                padding: 0.35rem 1rem;
                transition:
                    color 0.15s,
                    border-color 0.15s,
                    background-color 0.15s;
                z-index: 100;
                letter-spacing: 0.05em;
                white-space: nowrap;
                width: auto;
                box-sizing: border-box;
            }

            .search-trigger:hover {
                color: var(--text-primary);
                border-color: var(--text-secondary);
                background: var(--border);
            }

            @media (max-width: 600px) {
                .search-trigger {
                    bottom: calc(1.5rem + env(safe-area-inset-bottom, 0px));
                    left: 50%;
                    transform: translate3d(-50%, 0, 0);
                }
            }

            .search-overlay {
                position: fixed;
                inset: 0;
                background: rgba(0, 0, 0, 0.75);
                z-index: 200;
                display: flex;
                align-items: flex-start;
                justify-content: center;
                padding-top: 12vh;
                opacity: 0;
                pointer-events: none;
                transition: opacity 0.15s ease;
            }

            .search-overlay.active {
                opacity: 1;
                pointer-events: all;
            }

            .search-modal {
                width: 100%;
                max-width: 600px;
                margin: 0 1.5rem;
                background: var(--bg-secondary);
                border: 1px solid var(--border);
            }

            .search-input-wrap {
                display: flex;
                align-items: center;
                padding: 1rem 1.25rem;
                border-bottom: 1px solid var(--border);
                gap: 0.75rem;
            }

            .search-icon {
                color: var(--text-secondary);
                font-size: var(--size-base);
            }

            .search-input {
                flex: 1;
                background: none;
                border: none;
                color: var(--text-primary);
                font-family: var(--font);
                font-size: var(--size-base);
                padding: 0;
                outline: none;
                width: 100%;
            }

            .search-input::placeholder {
                color: var(--text-muted);
            }

            .search-esc {
                background: var(--bg);
                border: 1px solid var(--border);
                color: var(--text-secondary);
                padding: 0.15rem 0.4rem;
                font-size: var(--size-xs);
                font-family: var(--font);
                border-radius: 3px;
                box-shadow: 0 1px 0 var(--border);
            }

            .search-results {
                max-height: 50vh;
                overflow-y: auto;
                border-top: none;
            }

            .search-results:empty {
                display: none;
            }

            .pagefind-result {
                padding: 0.65rem 1.25rem;
            }

            .result-path {
                font-size: var(--size-base);
                font-weight: 700;
                color: var(--text-primary);
                display: block;
                margin-bottom: 0.25rem;
            }

            .result-path::after {
                display: none;
            }

            .result-excerpt {
                font-size: var(--size-sm);
                color: var(--text-secondary);
                line-height: 1.6;
                display: block;
                margin: 0;
            }

            .result-excerpt mark {
                background: none;
                color: #d4a017;
                font-weight: 700;
            }

            .no-results {
                padding: 1rem 1.25rem;
                font-size: var(--size-sm);
                color: var(--text-secondary);
            }
        </style>
    </head>
    <body>
        <button
            class="search-trigger"
            id="searchTrigger"
            aria-label="open search"
            data-pagefind-ignore>/ search</button
        >
        <Search />
        <slot />
        <script>
            document
                .getElementById("searchTrigger")
                ?.addEventListener("click", () => {
                    document.dispatchEvent(new CustomEvent("open-search"));
                });
        </script>
    </body>
</html>
